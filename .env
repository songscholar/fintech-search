# USES Indexer runtime configuration
# ==========================================
# 真实 Embedding 索引配置（全量构建）
# 请在下方填写你的 API Key 和 Base URL，然后执行建库命令

# ============================================================
# 1. Embedding 配置（必填）
# ============================================================

# 请填写你的 API Key（国内代理或 OpenAI 官方）
OPENAI_EMBEDDING_KEY=7fd66c84-5cf8-4e07-b997-4f4570bea81b

# 请填写你的 embedding 服务 base_url（兼容 OpenAI /v1 协议）
# 示例：https://oapi.aivue.cn/v1、https://api.openai.com/v1
OPENAI_EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 模型名称（推荐）
OPENAI_EMBEDDING_NAME=doubao-embedding-vision

# 批量大小（全量构建推荐 8，防止超时）
OPENAI_EMBEDDING_BATCH_SIZE=4

# 请求超时（秒，全量构建建议 120）
OPENAI_EMBEDDING_TIMEOUT=120

# Embedding 本地缓存（强烈建议启用，避免重复请求）
OPENAI_EMBEDDING_CACHE_DB=/Users/songzuoqiang/Documents/agent/condex/codes/examples/business_code_embedding_cache.db

# 也兼容 USES_INDEXER_EMBEDDING_* 变量名（二选一即可）
# USES_INDEXER_EMBEDDING_API_KEY=
# USES_INDEXER_EMBEDDING_MODEL=
# USES_INDEXER_EMBEDDING_BASE_URL=
# USES_INDEXER_EMBEDDING_BATCH_SIZE=8
# USES_INDEXER_EMBEDDING_TIMEOUT=120
# USES_INDEXER_EMBEDDING_CACHE_DB=/Users/songzuoqiang/Documents/agent/condex/codes/examples/business_code_embedding_cache.db

# ============================================================
# 2. LLM 回答层配置（可选，不填则回退到 draft_answer）
# ============================================================

USES_INDEXER_LLM_API_KEY=sk-kimi-GVGBpHt3MYf6PglJdlNaD2wo3rxkxwqtKePtdOaeqmBvv13JifglR5ND4vxXwwQl
USES_INDEXER_LLM_MODEL=kimi-for-coding
USES_INDEXER_LLM_BASE_URL=https://api.kimi.com/coding/v1/chat/completions
USES_INDEXER_LLM_TEMPERATURE=0.1
USES_INDEXER_LLM_MAX_TOKENS=1200

USES_INDEXER_LLM_USER_AGENT=claude-code/0.1.0
# ============================================================
# 3. Agent Gateway 配置（可选）
# ============================================================

USES_INDEXER_AGENT_OPENAI_MODEL=kimi-for-coding
USES_INDEXER_AGENT_OPENAI_BASE_URL=https://api.kimi.com/coding/v1/chat/completions
USES_INDEXER_AGENT_OPENAI_API_KEY=sk-kimi-GVGBpHt3MYf6PglJdlNaD2wo3rxkxwqtKePtdOaeqmBvv13JifglR5ND4vxXwwQl
USES_INDEXER_AGENT_OPENAI_USER_AGENT=claude-code/0.1.0
