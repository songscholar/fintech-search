# USES Indexer runtime configuration

# Optional explicit env file path override
# USES_INDEXER_ENV_FILE=/absolute/path/to/.env

# LLM answering
USES_INDEXER_LLM_PROVIDER=openai-compatible
USES_INDEXER_LLM_API_KEY=
USES_INDEXER_LLM_MODEL=
USES_INDEXER_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
USES_INDEXER_LLM_TEMPERATURE=0.1
USES_INDEXER_LLM_MAX_TOKENS=1200
USES_INDEXER_LLM_TIMEOUT=60
USES_INDEXER_LLM_MAX_RETRIES=0
USES_INDEXER_LLM_RETRY_BACKOFF=1.0

# Embeddings
USES_INDEXER_EMBEDDING_API_KEY=
USES_INDEXER_EMBEDDING_MODEL=
USES_INDEXER_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
USES_INDEXER_EMBEDDING_BATCH_SIZE=32
USES_INDEXER_EMBEDDING_DIMENSIONS=
USES_INDEXER_EMBEDDING_TIMEOUT=60
USES_INDEXER_EMBEDDING_CACHE_DB=

# Agent gateway
USES_INDEXER_AGENT_DEFAULT_PROVIDER=openai-compatible

# Generic OpenAI-compatible agent
USES_INDEXER_AGENT_OPENAI_MODEL=
USES_INDEXER_AGENT_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
USES_INDEXER_AGENT_OPENAI_API_KEY=
USES_INDEXER_AGENT_OPENAI_TEMPERATURE=0.1
USES_INDEXER_AGENT_OPENAI_MAX_TOKENS=1600
USES_INDEXER_AGENT_OPENAI_TIMEOUT=90
USES_INDEXER_AGENT_OPENAI_MAX_RETRIES=0
USES_INDEXER_AGENT_OPENAI_RETRY_BACKOFF=1.0

# Hermes adapter reservation (currently routed as openai-compatible HTTP chat)
USES_INDEXER_AGENT_HERMES_MODEL=
USES_INDEXER_AGENT_HERMES_BASE_URL=
USES_INDEXER_AGENT_HERMES_API_KEY=
USES_INDEXER_AGENT_HERMES_TEMPERATURE=0.1
USES_INDEXER_AGENT_HERMES_MAX_TOKENS=1600
USES_INDEXER_AGENT_HERMES_TIMEOUT=90
USES_INDEXER_AGENT_HERMES_MAX_RETRIES=0
USES_INDEXER_AGENT_HERMES_RETRY_BACKOFF=1.0

# OpenClaw adapter reservation (currently routed as openai-compatible HTTP chat)
USES_INDEXER_AGENT_OPENCLAW_MODEL=
USES_INDEXER_AGENT_OPENCLAW_BASE_URL=
USES_INDEXER_AGENT_OPENCLAW_API_KEY=
USES_INDEXER_AGENT_OPENCLAW_TEMPERATURE=0.1
USES_INDEXER_AGENT_OPENCLAW_MAX_TOKENS=1600
USES_INDEXER_AGENT_OPENCLAW_TIMEOUT=90
USES_INDEXER_AGENT_OPENCLAW_MAX_RETRIES=0
USES_INDEXER_AGENT_OPENCLAW_RETRY_BACKOFF=1.0
