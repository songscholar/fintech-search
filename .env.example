# USES Indexer runtime configuration

# Optional explicit env file path override
# USES_INDEXER_ENV_FILE=/absolute/path/to/.env

# ============================================================
# LLM Provider 选择（kimi | xiaomi）
# ============================================================
USES_INDEXER_LLM_PROVIDER=kimi

# ============================================================
# Kimi 配置
# ============================================================
KIMI_LLM_API_KEY=
KIMI_LLM_MODEL=kimi-k2
KIMI_LLM_BASE_URL=https://api.moonshot.cn/v1/chat/completions
KIMI_LLM_TEMPERATURE=0.1
KIMI_LLM_MAX_TOKENS=1200
KIMI_LLM_TIMEOUT=180
KIMI_LLM_MAX_RETRIES=0
KIMI_LLM_RETRY_BACKOFF=1.0
KIMI_LLM_USER_AGENT=

# ============================================================
# Xiaomi 配置
# ============================================================
XIAOMI_LLM_API_KEY=
XIAOMI_LLM_MODEL=MiMo-72B
XIAOMI_LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1/chat/completions
XIAOMI_LLM_TEMPERATURE=0.1
XIAOMI_LLM_MAX_TOKENS=1200
XIAOMI_LLM_TIMEOUT=180
XIAOMI_LLM_MAX_RETRIES=0
XIAOMI_LLM_RETRY_BACKOFF=1.0
XIAOMI_LLM_USER_AGENT=

# ============================================================
# Embeddings
# ============================================================
USES_INDEXER_EMBEDDING_API_KEY=
USES_INDEXER_EMBEDDING_MODEL=
USES_INDEXER_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
USES_INDEXER_EMBEDDING_BATCH_SIZE=32
USES_INDEXER_EMBEDDING_DIMENSIONS=
USES_INDEXER_EMBEDDING_TIMEOUT=60
USES_INDEXER_EMBEDDING_CACHE_DB=
